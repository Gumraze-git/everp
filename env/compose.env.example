# Host ports exposed by docker-compose
EVERP_FRONTEND_PORT=13000
EVERP_GW_PORT=18080
EVERP_AUTH_PORT=18081
EVERP_BUSINESS_PORT=18082
EVERP_ALARM_PORT=18083
EVERP_SCM_PORT=18084
EVERP_POSTGRES_PORT=15432
EVERP_REDIS_PORT=16379
EVERP_KAFKA_PORT=19092

# Public local URLs used by auth/gateway/frontend.
# If you change frontend/auth ports, keep these values in sync.
EVERP_FRONTEND_ORIGIN=http://localhost:13000
EVERP_AUTH_ISSUER=http://localhost:18081
EVERP_OAUTH_REDIRECT_URI=http://localhost:13000/callback
